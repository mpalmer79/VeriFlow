# Points the SPA at the backend's public origin, including the /api
# prefix. On Railway this is the public URL of the backend service
# (e.g. https://veriflow-backend-production.up.railway.app/api). This
# value is inlined at build time; changing it requires a rebuild.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Set to `true` on a public portfolio deployment. In demo mode the
# frontend auto-signs-in as the admin seeded account on first visit
# and exposes a `/roles` page for walking through role-based access.
# Leave unset (or set to an empty string) on real production deploys.
NEXT_PUBLIC_DEMO_MODE=
