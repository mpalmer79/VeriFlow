# App lifecycle. Keep APP_ENV dev-like locally so migrations + seed run;
# set to production on hosted deploys (seeds then refuse to execute
# unless VERIFLOW_ALLOW_SEED=true is also set).
APP_ENV=development
APP_NAME=VeriFlow
API_V1_PREFIX=/api

# Database. Postgres is the expected hosted target; SQLite is fine for
# local iteration. Railway exposes this via the DATABASE_URL variable
# on the attached Postgres plugin — reference it from the backend
# service as ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgresql+psycopg2://veriflow:veriflow@localhost:5432/veriflow

# JWT signing. Generate a strong secret for non-dev envs; the default
# value is refused at startup outside dev environments.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# CORS. Comma-separated origins. Must include the deployed frontend URL
# so the SPA and signed-content preview iframes work.
CORS_ORIGINS=http://localhost:3000

# Evidence storage. On Railway this must point at a mounted volume so
# uploads survive redeploys (Railway's app FS is ephemeral).
EVIDENCE_STORAGE_DIR=./evidence
MAX_UPLOAD_BYTES=26214400

# Rate-limit windows (per minute per IP+route). 0 disables a bucket.
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_SIGNED_ACCESS_PER_MINUTE=60

# Opt-in override to run the demo seed in a non-dev environment.
# Leave unset on production deploys.
# VERIFLOW_ALLOW_SEED=true
